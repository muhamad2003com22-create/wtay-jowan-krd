rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Valid ID format and safety bounds
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin authorization rule
    // Prefixes automatic access for muhamad2003.com22@gmail.com
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'muhamad2003.com22@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 1. Users profiles rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming());
      allow update: if isSignedIn() && (
        isAdmin() ||
        (userId == request.auth.uid && isValidUser(incoming()) && incoming().isAdmin == existing().isAdmin && incoming().email == existing().email)
      );
      allow delete: if isAdmin();
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'joinedAt']) &&
             data.keys().size() <= 7 &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.displayName is string &&
             data.displayName.size() <= 100 &&
             (!data.keys().hasAny(['bio']) || (data.bio is string && data.bio.size() <= 500)) &&
             (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 200000)) &&
             (!data.keys().hasAny(['isAdmin']) || data.isAdmin is bool);
    }

    // 2. Quotes rules
    match /quotes/{quoteId} {
      allow read: if true; // anyone can read shared quotes
      allow create: if isSignedIn() && isValidId(quoteId) && isValidQuote(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isValidQuote(incoming()) && (
        (isSignedIn() && (
          isAdmin() ||
          (existing().userId == request.auth.uid && incoming().userId == existing().userId && incoming().createdAt == existing().createdAt)
        )) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['viewsCount', 'likesCount', 'commentsCount']))
      );
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    function isValidQuote(data) {
      return data.keys().hasAll(['id', 'text', 'author', 'userId', 'userDisplayName', 'createdAt', 'likesCount', 'viewsCount', 'commentsCount']) &&
             data.keys().size() <= 11 &&
             data.id is string &&
             data.text is string && data.text.size() <= 2000 &&
             data.author is string && data.author.size() <= 100 &&
             (!data.keys().hasAny(['category']) || (data.category is string && data.category.size() <= 50)) &&
             data.userId is string &&
             data.userDisplayName is string &&
             (!data.keys().hasAny(['userPhotoURL']) || (data.userPhotoURL is string && data.userPhotoURL.size() <= 200000)) &&
             data.likesCount is int &&
             data.viewsCount is int &&
             data.commentsCount is int;
    }

    // 3. Likes subcollection
    match /quotes/{quoteId}/likes/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && userId == request.auth.uid && isValidId(quoteId);
      allow delete: if isSignedIn() && (userId == request.auth.uid || isAdmin());
    }

    // 4. Comments subcollection
    match /quotes/{quoteId}/comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(commentId) && isValidComment(incoming()) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    function isValidComment(data) {
      return data.keys().hasAll(['id', 'quoteId', 'userId', 'userDisplayName', 'text', 'createdAt']) &&
             data.keys().size() <= 7 &&
             data.id is string &&
             data.quoteId is string &&
             data.userId is string &&
             data.userDisplayName is string &&
             (!data.keys().hasAny(['userPhotoURL']) || (data.userPhotoURL is string && data.userPhotoURL.size() <= 200000)) &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 500 &&
             data.createdAt is string;
    }

    // 4. AdminLogs
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && isValidLog(incoming());
      allow update, delete: if isAdmin();
    }

    function isValidLog(data) {
      return data.keys().hasAll(['id', 'eventType', 'userId', 'userEmail', 'userName', 'timestamp']) &&
             data.keys().size() <= 7 &&
             data.eventType is string &&
             data.userId is string &&
             data.userEmail is string &&
             data.userName is string &&
             (!data.keys().hasAny(['details']) || (data.details is string && data.details.size() <= 1000));
    }
  }
}
